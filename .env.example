# Backend server manzili
# Local dev: http://localhost:4444
# Production: https://your-backend.vercel.app
NEXT_PUBLIC_API_URL=http://localhost:4444

# GROQ AI key (https://console.groq.com — bepul) — o'zingizning kalitingizni kiriting
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
